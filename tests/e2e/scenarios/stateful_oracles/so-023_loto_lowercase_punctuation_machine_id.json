{
  "id": "SO-023",
  "title": "LOTO lowercase and punctuation machine ID",
  "risk": "Lowercase or punctuation-heavy LOTO wording can lose the machine ID, ask for it again, or route away from RAG despite a valid M-CNC-01 reference.",
  "prompt": "need lockout tagout for m-cnc-01 before service",
  "initial_state": {
    "machines": [
      {
        "id": "M-CNC-01",
        "status": "running",
        "cell": "CNC"
      }
    ],
    "rag_sources": [
      {
        "source_id": "SRC-LOTO-CNC-01",
        "machine_id": "M-CNC-01",
        "title": "LOTO Procedure for CNC Cell"
      }
    ],
    "approvals": [],
    "audit_rows": []
  },
  "expected_route": {
    "route": "rag.loto_procedure",
    "machine_id": "M-CNC-01",
    "normalized_from": "m-cnc-01",
    "must_not_route_to": [
      "clarification.machine_id_missing",
      "tool.read.machine_status"
    ]
  },
  "expected_approvals": [],
  "expected_intermediate_states": [
    {
      "after": "entity extraction",
      "session_phase": "EXECUTING",
      "machine_id": "M-CNC-01",
      "normalized_from": "m-cnc-01",
      "missing_required_entities": []
    },
    {
      "after": "rag retrieval",
      "session_phase": "EXECUTING",
      "source_ids": [
        "SRC-LOTO-CNC-01"
      ],
      "forbidden": [
        "ask_for_machine_id_again",
        "machine_status_tool_call"
      ]
    }
  ],
  "expected_final_state": {
    "session_phase": "COMPLETED",
    "machines": [
      {
        "id": "M-CNC-01",
        "status": "running",
        "cell": "CNC"
      }
    ],
    "pending_approval_id": null
  },
  "expected_audit_rows": [],
  "expected_timeline": [
    {
      "event": "operation_started"
    },
    {
      "event": "intent_split",
      "intent_count": 1
    },
    {
      "event": "route_selected",
      "route": "rag.loto_procedure"
    },
    {
      "event": "rag_retrieval_completed",
      "machine_id": "M-CNC-01",
      "source_ids": [
        "SRC-LOTO-CNC-01"
      ]
    },
    {
      "event": "final_response_created"
    },
    {
      "event": "operation_completed"
    }
  ],
  "expected_sse_or_snapshot": {
