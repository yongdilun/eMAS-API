    "seeded_browser"
  ],
  "weakness_from_phase0": "Existing successful LOTO coverage used cleaner wording or slash-separated lockout/tagout; this exact normal-use phrase proves lowercase normalization and route selection for plain 'lockout tagout'.",
  "phase13_quality_gate": {
    "real_product_bug_caught": "Lowercase m-cnc-01 plus plain lockout tagout wording can fail normalization and fall back to a clarification or wrong route.",
    "existing_test_that_would_miss_it": "SO-021 covers a canonical uppercase ID, and the prior bank wording used lockout/tagout with a slash rather than this punctuation-free operator phrasing.",
