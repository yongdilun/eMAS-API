    "terminal": {
      "status": "COMPLETED",
      "pending_approval_id": null,
      "route": "rag.loto_procedure",
      "source_ids": [
        "SRC-LOTO-CNC-01"
      ]
    }
  },
  "expected_final_response": {
    "allowed_after": "rag_retrieval_completed M-CNC-01",
    "must_include": [
      "M-CNC-01",
      "LOTO",
