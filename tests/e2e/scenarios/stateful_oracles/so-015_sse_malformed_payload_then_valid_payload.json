{
  "id": "SO-015",
  "title": "SSE malformed payload then valid payload",
  "risk": "A malformed stream event can crash the activity handler or leave the UI stuck even though the next valid snapshot/event completes the operation.",
  "prompt": "Change all high priority jobs to medium.",
  "initial_state": {
    "jobs": [
      {
        "id": "JOB-SO015-HIGH-01",
        "priority": "high",
        "status": "open"
      },
      {
        "id": "JOB-SO015-LOW-01",
        "priority": "low",
        "status": "open"
      }
    ],
    "approvals": [],
    "audit_rows": [],
    "stream_faults": [
      {
        "event_id": "evt-so-015-bad",
        "payload": "{not-json",
        "expected_handling": "ignore_and_continue"
      }
    ]
  },
  "expected_intents": [
    {
      "intent_id": "SO-015-I1",
      "route": "tool.write.jobs.bulk_update_priority",
      "filter": {
        "priority": "high"
      },
      "new_values": {
        "priority": "medium"
      },
      "source_row_ids": [
        "JOB-SO015-HIGH-01"
      ]
    }
  ],
  "expected_approvals": [
    {
      "approval_id": "approval-so-015-1",
      "intent_id": "SO-015-I1",
      "decision": "accepted",
      "row_ids": [
        "JOB-SO015-HIGH-01"
      ],
      "row_count": 1
    }
  ],
  "expected_intermediate_states": [
    {
      "after": "malformed SSE payload",
      "session_phase": "EXECUTING",
      "pending_approval_id": null,
      "client_stream_state": "connected",
      "forbidden": [
        "uncaught_exception",
        "permanent_busy_state",
        "terminal_assistant_message"
      ]
    },
    {
      "after": "next valid SSE payload",
      "session_phase": "COMPLETED",
      "pending_approval_id": null,
      "client_stream_state": "healthy"
    }
  ],
  "expected_final_state": {
    "session_phase": "COMPLETED",
    "jobs": [
      {
        "id": "JOB-SO015-HIGH-01",
        "priority": "medium"
      },
      {
        "id": "JOB-SO015-LOW-01",
        "priority": "low"
      }
    ],
    "pending_approval_id": null
  },
  "expected_audit_rows": [
    {
      "approval_id": "approval-so-015-1",
      "action": "bulk_update_job_priority",
      "row_ids": [
        "JOB-SO015-HIGH-01"
      ],
      "from": "high",
      "to": "medium",
      "status": "success"
    }
  ],
  "expected_timeline": [
    {
      "event": "operation_started"
    },
    {
      "event": "approval_requested",
      "approval_id": "approval-so-015-1"
    },
    {
      "event": "approval_decided",
      "approval_id": "approval-so-015-1",
      "decision": "accepted"
    },
    {
      "event": "sse_malformed_payload_ignored",
      "event_id": "evt-so-015-bad"
    },
    {
      "event": "commit_completed",
      "approval_id": "approval-so-015-1"
    },
    {
      "event": "final_response_created"
    },
    {
      "event": "operation_completed"
    }
  ],
  "expected_sse_or_snapshot": {
    "malformed_event": {
      "event_id": "evt-so-015-bad",
      "expected_client_behavior": "ignore_and_continue",
      "must_not_close_stream": true
    },
    "terminal": {
      "status": "COMPLETED",
      "pending_approval_id": null,
      "valid_event_after_malformed_payload_updates_ui": true
    }
  },
  "expected_final_response": {
    "allowed_after": "operation_completed",
    "must_include": [
      "1 high priority job changed to medium"
    ],
    "must_not_include": [
      "stream failed",
      "Factory Agent needs attention"
    ]
  },
  "expected_ui": {
    "approval_cards_in_order": [
      "approval-so-015-1"
    ],
    "must_show": [
      "Run complete",
      "1 high priority job changed to medium"
    ],
    "must_not_show": [
      "stuck",
      "stream parse error",
      "Factory Agent needs attention"
    ]
  },
  "expected_unchanged_rows": [
    {
      "id": "JOB-SO015-LOW-01",
      "priority": "low"
    }
  ],
  "invariants": [
    "malformed_sse_payload_is_ignored",
    "next_valid_sse_updates_state",
    "sse_matches_snapshot",
    "commit_matches_approval_bundle",
    "final_summary_matches_commits"
  ],
  "required_layers": [
    "playwright_sse"
  ],
  "weakness_from_phase0": "Phase 0 found SSE checks that accepted visible activity; this oracle requires malformed payload recovery plus a later valid terminal update.",
  "executable_enforcement": {
    "pytest": [
      "factory-agent/tests/test_snapshot_timeline_final_response_contract.py::test_all_stateful_oracle_files_have_executable_snapshot_final_response_contract"
    ],
    "playwright": [
      "eMas Front/e2e/specs/chat-stream-errors.spec.js::SO-015 malformed SSE payload"
    ],
    "visible_dom_assertions_required": true,
    "manual_prompt_regression": [],
    "tracker": "docs/qa/STATEFUL_ORACLE_TESTING_TRACK.md#phase-12-executable-enforcement-closure"
  }
}
