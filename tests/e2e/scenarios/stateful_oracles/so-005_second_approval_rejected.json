{
  "id": "SO-005",
  "title": "Approval 1 accepted, approval 2 rejected",
  "risk": "Rejecting the second approval can still allow hidden continuation, a second commit, or a misleading final success message.",
  "prompt": "Change all medium priority jobs to high, then change all original high priority jobs to low. Approve the first request and reject the second.",
  "initial_state": {
    "jobs": [
      {
        "id": "JOB-SO005-HIGH-01",
        "priority": "high",
        "status": "open"
      },
      {
        "id": "JOB-SO005-HIGH-02",
        "priority": "high",
        "status": "open"
      },
      {
        "id": "JOB-SO005-MED-01",
        "priority": "medium",
        "status": "open"
      },
      {
        "id": "JOB-SO005-LOW-01",
        "priority": "low",
        "status": "open"
      }
    ],
    "approvals": [],
    "audit_rows": []
  },
  "expected_intents": [
    {
      "intent_id": "SO-005-I1",
      "route": "tool.write.jobs.bulk_update_priority",
      "filter": {
        "priority": "medium"
      },
      "new_values": {
        "priority": "high"
      },
      "source_row_ids": [
        "JOB-SO005-MED-01"
      ]
    },
    {
      "intent_id": "SO-005-I2",
      "route": "tool.write.jobs.bulk_update_priority",
      "filter": {
        "priority": "high",
        "state_basis": "original"
      },
      "new_values": {
        "priority": "low"
      },
      "source_row_ids": [
        "JOB-SO005-HIGH-01",
        "JOB-SO005-HIGH-02"
      ]
    }
  ],
  "expected_approvals": [
    {
      "approval_id": "approval-so-005-1",
      "intent_id": "SO-005-I1",
      "decision": "accepted",
      "row_ids": [
        "JOB-SO005-MED-01"
      ],
      "row_count": 1
    },
    {
      "approval_id": "approval-so-005-2",
      "intent_id": "SO-005-I2",
      "decision": "rejected",
      "row_ids": [
        "JOB-SO005-HIGH-01",
        "JOB-SO005-HIGH-02"
      ],
      "row_count": 2
    }
  ],
  "expected_intermediate_states": [
    {
      "after": "approval-so-005-1 commit",
      "session_phase": "WAITING_APPROVAL",
      "pending_approval_id": "approval-so-005-2",
      "jobs": [
        {
          "id": "JOB-SO005-HIGH-01",
          "priority": "high"
        },
        {
          "id": "JOB-SO005-HIGH-02",
          "priority": "high"
        },
        {
          "id": "JOB-SO005-MED-01",
          "priority": "high"
        },
        {
          "id": "JOB-SO005-LOW-01",
          "priority": "low"
        }
      ]
    },
    {
      "after": "approval-so-005-2 rejected",
      "session_phase": "CANCELLED",
      "pending_approval_id": null,
      "forbidden": [
        "commit_started for approval-so-005-2",
        "commit_completed for approval-so-005-2"
      ]
    }
  ],
  "expected_final_state": {
    "session_phase": "CANCELLED",
    "jobs": [
      {
        "id": "JOB-SO005-HIGH-01",
        "priority": "high"
      },
      {
        "id": "JOB-SO005-HIGH-02",
        "priority": "high"
      },
      {
        "id": "JOB-SO005-MED-01",
        "priority": "high"
      },
      {
        "id": "JOB-SO005-LOW-01",
        "priority": "low"
      }
    ],
    "pending_approval_id": null
  },
  "expected_audit_rows": [
    {
      "approval_id": "approval-so-005-1",
      "action": "bulk_update_job_priority",
      "row_ids": [
        "JOB-SO005-MED-01"
      ],
      "from": "medium",
      "to": "high",
      "status": "success"
    }
  ],
  "expected_timeline": [
    {
      "event": "operation_started"
    },
    {
      "event": "intent_split",
      "intent_count": 2
    },
    {
      "event": "approval_requested",
      "approval_id": "approval-so-005-1"
    },
    {
      "event": "approval_decided",
      "approval_id": "approval-so-005-1",
      "decision": "accepted"
    },
    {
      "event": "commit_completed",
      "approval_id": "approval-so-005-1"
    },
    {
      "event": "approval_requested",
      "approval_id": "approval-so-005-2"
    },
    {
      "event": "approval_decided",
      "approval_id": "approval-so-005-2",
      "decision": "rejected"
    },
    {
      "event": "operation_cancelled",
      "reason": "approval_rejected"
    }
  ],
  "expected_sse_or_snapshot": {
    "after_rejection": {
      "status": "CANCELLED",
      "pending_approval_id": null,
      "must_not_include_events": [
        "commit_completed approval-so-005-2",
        "operation_completed"
      ]
    }
  },
  "expected_final_response": {
    "allowed_after": "approval_decided approval-so-005-2 rejected",
    "must_include": [
      "First change was committed",
      "second approval was rejected"
    ],
    "must_not_include": [
      "all requested changes completed",
      "2 original high priority jobs changed to low"
    ]
  },
  "expected_ui": {
    "approval_cards_in_order": [
      "approval-so-005-1",
      "approval-so-005-2"
    ],
    "must_show": [
      "Rejected",
      "First change was committed"
    ],
    "must_not_show": [
      "Run complete",
      "2 original high priority jobs changed to low"
    ]
  },
  "expected_unchanged_rows": [
    {
      "id": "JOB-SO005-HIGH-01",
      "priority": "high"
    },
    {
      "id": "JOB-SO005-HIGH-02",
      "priority": "high"
    },
    {
      "id": "JOB-SO005-LOW-01",
      "priority": "low"
    }
  ],
  "invariants": [
    "approval_ids_are_distinct",
    "rejection_stops_hidden_continuation",
    "no_commit_after_rejected_approval",
    "pending_approval_matches_snapshot",
    "timeline_contains_transition_chain",
    "final_summary_matches_commits"
  ],
  "required_layers": [
    "pytest_graph",
    "browser"
  ],
  "weakness_from_phase0": "Existing orchestration tests check that rejection is visible, but do not prove the second write never commits, no success audit row is appended, and final UI does not claim full success.",
  "executable_enforcement": {
    "pytest": [
      "factory-agent/tests/test_snapshot_timeline_final_response_contract.py::test_all_stateful_oracle_files_have_executable_snapshot_final_response_contract"
    ],
    "playwright": [
      "eMas Front/e2e/specs/full-stack-data-integrity.spec.js::SO-005 scenario 86"
    ],
    "visible_dom_assertions_required": true,
    "manual_prompt_regression": [
      "tests/e2e/scenarios/manual_prompt_regressions.json::phase12-so005-medium-high-high-low-reject-approval-2"
    ],
    "tracker": "docs/qa/STATEFUL_ORACLE_TESTING_TRACK.md#phase-12-executable-enforcement-closure"
  }
}
