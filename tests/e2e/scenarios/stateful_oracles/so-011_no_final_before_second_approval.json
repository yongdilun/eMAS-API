{
  "id": "SO-011",
  "title": "Final response before approval 2 appears",
  "risk": "A session can emit or render a terminal assistant response after the first commit even though the second approval has not been requested or decided.",
  "prompt": "Change all medium priority jobs to high, then change all original high priority jobs to medium.",
  "initial_state": {
    "jobs": [
      {
        "id": "JOB-SO011-HIGH-01",
        "priority": "high",
        "status": "open"
      },
      {
        "id": "JOB-SO011-MED-01",
        "priority": "medium",
        "status": "open"
      },
      {
        "id": "JOB-SO011-MED-02",
        "priority": "medium",
        "status": "open"
      },
      {
        "id": "JOB-SO011-LOW-01",
        "priority": "low",
        "status": "open"
      }
    ],
    "approvals": [],
    "audit_rows": []
  },
  "expected_intents": [
    {
      "intent_id": "SO-011-I1",
      "route": "tool.write.jobs.bulk_update_priority",
      "filter": {
        "priority": "medium"
      },
      "new_values": {
        "priority": "high"
      },
      "source_row_ids": [
        "JOB-SO011-MED-01",
        "JOB-SO011-MED-02"
      ]
    },
    {
      "intent_id": "SO-011-I2",
      "route": "tool.write.jobs.bulk_update_priority",
      "filter": {
        "priority": "high",
        "state_basis": "original"
      },
      "new_values": {
        "priority": "medium"
      },
      "source_row_ids": [
        "JOB-SO011-HIGH-01"
      ]
    }
  ],
  "expected_approvals": [
    {
      "approval_id": "approval-so-011-1",
      "intent_id": "SO-011-I1",
      "decision": "accepted",
      "row_ids": [
        "JOB-SO011-MED-01",
        "JOB-SO011-MED-02"
      ],
      "row_count": 2
    },
    {
      "approval_id": "approval-so-011-2",
      "intent_id": "SO-011-I2",
      "decision": "accepted",
      "row_ids": [
        "JOB-SO011-HIGH-01"
      ],
      "row_count": 1
    }
  ],
  "expected_intermediate_states": [
    {
      "after": "approval-so-011-1 commit before approval-so-011-2 requested",
      "session_phase": "EXECUTING",
      "pending_approval_id": null,
      "forbidden": [
        "final_response_created",
        "operation_completed",
        "terminal_assistant_message"
      ]
    },
    {
      "after": "approval-so-011-2 requested",
      "session_phase": "WAITING_APPROVAL",
      "pending_approval_id": "approval-so-011-2",
      "forbidden": [
        "final_response_created",
        "operation_completed",
        "terminal_assistant_message"
      ]
    }
  ],
  "expected_final_state": {
    "session_phase": "COMPLETED",
    "jobs": [
      {
        "id": "JOB-SO011-HIGH-01",
        "priority": "medium"
      },
      {
        "id": "JOB-SO011-MED-01",
        "priority": "high"
      },
      {
        "id": "JOB-SO011-MED-02",
        "priority": "high"
      },
      {
        "id": "JOB-SO011-LOW-01",
        "priority": "low"
      }
    ],
    "pending_approval_id": null
  },
  "expected_audit_rows": [
    {
      "approval_id": "approval-so-011-1",
      "action": "bulk_update_job_priority",
      "row_ids": [
        "JOB-SO011-MED-01",
        "JOB-SO011-MED-02"
      ],
      "from": "medium",
      "to": "high",
      "status": "success"
    },
    {
      "approval_id": "approval-so-011-2",
      "action": "bulk_update_job_priority",
      "row_ids": [
        "JOB-SO011-HIGH-01"
      ],
      "from": "high",
      "to": "medium",
      "status": "success"
    }
  ],
  "expected_timeline": [
    {
      "event": "operation_started"
    },
    {
      "event": "intent_split",
      "intent_count": 2
    },
    {
      "event": "approval_requested",
      "approval_id": "approval-so-011-1"
    },
    {
      "event": "approval_decided",
      "approval_id": "approval-so-011-1",
      "decision": "accepted"
    },
    {
      "event": "commit_completed",
      "approval_id": "approval-so-011-1"
    },
    {
      "event": "next_intent_started",
      "intent_id": "SO-011-I2"
    },
    {
      "event": "approval_requested",
      "approval_id": "approval-so-011-2"
    },
    {
      "event": "approval_decided",
      "approval_id": "approval-so-011-2",
      "decision": "accepted"
    },
    {
      "event": "commit_completed",
      "approval_id": "approval-so-011-2"
    },
    {
      "event": "final_response_created"
    },
    {
      "event": "operation_completed"
    }
  ],
  "expected_sse_or_snapshot": {
    "before_second_approval": {
      "status": "EXECUTING",
      "must_not_include_events": [
        "final_response_created",
        "operation_completed"
      ],
      "must_not_include_final_message": true
    },
    "waiting_on_second_approval": {
      "status": "WAITING_APPROVAL",
      "pending_approval_id": "approval-so-011-2",
      "must_not_include_final_message": true
    },
    "terminal": {
      "status": "COMPLETED",
      "pending_approval_id": null
    }
  },
  "expected_final_response": {
    "allowed_after": "commit_completed approval-so-011-2",
    "must_include": [
      "2 medium priority jobs changed to high",
      "1 original high priority job changed to medium"
    ],
    "must_not_include": [
      "Run complete before the second approval",
      "waiting approval but completed"
    ]
  },
  "expected_ui": {
    "approval_cards_in_order": [
      "approval-so-011-1",
      "approval-so-011-2"
    ],
    "before_second_approval_must_not_show": [
      "Run complete",
      "2 medium priority jobs changed to high and 1 original high priority job changed to medium"
    ],
    "must_show_after_terminal": [
      "Run complete",
      "1 original high priority job changed to medium"
    ]
  },
  "expected_unchanged_rows": [
    {
      "id": "JOB-SO011-LOW-01",
      "priority": "low"
    }
  ],
  "invariants": [
    "no_final_before_terminal",
    "no_final_response_before_second_approval",
    "pending_approval_matches_snapshot",
    "approval_ids_are_distinct",
    "timeline_contains_transition_chain",
    "sse_matches_snapshot"
  ],
  "required_layers": [
    "pytest_snapshot",
    "browser"
  ],
  "weakness_from_phase0": "Phase 0 found many tests that assert final COMPLETED state only; this oracle specifically guards the boundary where final response appears before approval 2 is requested or completed.",
  "executable_enforcement": {
    "pytest": [
      "factory-agent/tests/test_snapshot_timeline_final_response_contract.py::test_all_stateful_oracle_files_have_executable_snapshot_final_response_contract"
    ],
    "playwright": [
      "eMas Front/e2e/specs/real-langgraph-critical.spec.js::SO-041 pending approval DOM assertions"
    ],
    "visible_dom_assertions_required": true,
    "manual_prompt_regression": [],
    "tracker": "docs/qa/STATEFUL_ORACLE_TESTING_TRACK.md#phase-12-executable-enforcement-closure"
  }
}
