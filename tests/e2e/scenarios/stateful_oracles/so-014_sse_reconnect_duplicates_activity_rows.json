{
  "id": "SO-014",
  "title": "SSE reconnect duplicates old activity rows",
  "risk": "Reconnecting with Last-Event-ID can replay semantic activity rows and make the browser timeline show duplicate approvals, commits, or terminal messages.",
  "prompt": "Change all high priority jobs to medium.",
  "initial_state": {
    "jobs": [
      {
        "id": "JOB-SO014-HIGH-01",
        "priority": "high",
        "status": "open"
      },
      {
        "id": "JOB-SO014-HIGH-02",
        "priority": "high",
        "status": "open"
      },
      {
        "id": "JOB-SO014-LOW-01",
        "priority": "low",
        "status": "open"
      }
    ],
    "approvals": [],
    "audit_rows": [],
    "stream_reconnect": {
      "disconnect_after_event_id": "evt-so-014-004",
      "reconnect_last_event_id": "evt-so-014-004"
    }
  },
  "expected_intents": [
    {
      "intent_id": "SO-014-I1",
      "route": "tool.write.jobs.bulk_update_priority",
      "filter": {
        "priority": "high"
      },
      "new_values": {
        "priority": "medium"
      },
      "source_row_ids": [
        "JOB-SO014-HIGH-01",
        "JOB-SO014-HIGH-02"
      ]
    }
  ],
  "expected_approvals": [
    {
      "approval_id": "approval-so-014-1",
      "intent_id": "SO-014-I1",
      "decision": "accepted",
      "row_ids": [
        "JOB-SO014-HIGH-01",
        "JOB-SO014-HIGH-02"
      ],
      "row_count": 2
    }
  ],
  "expected_intermediate_states": [
    {
      "after": "stream reconnect",
      "session_phase": "EXECUTING",
      "pending_approval_id": null,
      "rendered_activity_ids_must_be_unique": true,
      "must_not_duplicate_semantic_events": [
        "approval_requested approval-so-014-1",
        "approval_decided approval-so-014-1"
      ]
    }
  ],
  "expected_final_state": {
    "session_phase": "COMPLETED",
    "jobs": [
      {
        "id": "JOB-SO014-HIGH-01",
        "priority": "medium"
      },
      {
        "id": "JOB-SO014-HIGH-02",
        "priority": "medium"
      },
      {
        "id": "JOB-SO014-LOW-01",
        "priority": "low"
      }
    ],
    "pending_approval_id": null
  },
  "expected_audit_rows": [
    {
      "approval_id": "approval-so-014-1",
      "action": "bulk_update_job_priority",
      "row_ids": [
        "JOB-SO014-HIGH-01",
        "JOB-SO014-HIGH-02"
      ],
      "from": "high",
      "to": "medium",
      "status": "success"
    }
  ],
  "expected_timeline": [
    {
      "event": "operation_started",
      "event_id": "evt-so-014-001"
    },
    {
      "event": "approval_requested",
      "approval_id": "approval-so-014-1",
      "event_id": "evt-so-014-002"
    },
    {
      "event": "approval_decided",
      "approval_id": "approval-so-014-1",
      "decision": "accepted",
      "event_id": "evt-so-014-003"
    },
    {
      "event": "commit_started",
      "approval_id": "approval-so-014-1",
      "event_id": "evt-so-014-004"
    },
    {
      "event": "stream_reconnected",
      "last_event_id": "evt-so-014-004"
    },
    {
      "event": "commit_completed",
      "approval_id": "approval-so-014-1",
      "event_id": "evt-so-014-005"
    },
    {
      "event": "final_response_created",
      "event_id": "evt-so-014-006"
    },
    {
      "event": "operation_completed",
      "event_id": "evt-so-014-007"
    }
  ],
  "expected_sse_or_snapshot": {
    "after_reconnect": {
      "status": "EXECUTING",
      "must_not_replay_before_or_equal_event_id": "evt-so-014-004",
      "activity_ids_unique": true
    },
    "terminal": {
      "status": "COMPLETED",
      "pending_approval_id": null,
      "timeline_contains_once": [
        "approval-so-014-1",
        "commit_completed approval-so-014-1",
        "operation_completed"
      ]
    }
  },
  "expected_final_response": {
    "allowed_after": "operation_completed evt-so-014-007",
    "must_include": [
      "2 high priority jobs changed to medium"
    ],
    "must_not_include": [
      "duplicate",
      "4 high priority jobs changed"
    ]
  },
  "expected_ui": {
    "approval_cards_in_order": [
      "approval-so-014-1"
    ],
    "must_show": [
      "Run complete",
      "2 high priority jobs changed to medium"
    ],
    "must_not_show": [
      "two Run complete rows",
      "duplicate approval",
      "Factory Agent needs attention"
    ]
  },
  "expected_unchanged_rows": [
    {
      "id": "JOB-SO014-LOW-01",
      "priority": "low"
    }
  ],
  "invariants": [
    "sse_reconnect_uses_last_event_id",
    "no_duplicate_activity_rows_after_reconnect",
    "sse_matches_snapshot",
    "commit_matches_approval_bundle",
    "timeline_contains_transition_chain",
    "final_summary_matches_commits"
  ],
  "required_layers": [
    "playwright_sse"
  ],
  "weakness_from_phase0": "Existing reconnect tests checked that Last-Event-ID was sent but not that replayed activity rows are de-duplicated semantically in timeline and UI.",
  "executable_enforcement": {
    "pytest": [
      "factory-agent/tests/test_snapshot_timeline_final_response_contract.py::test_all_stateful_oracle_files_have_executable_snapshot_final_response_contract"
    ],
    "playwright": [
      "eMas Front/e2e/specs/full-stack-sse-hard.spec.js::SO-014 scenario 47",
      "eMas Front/e2e/specs/full-stack-sse-hard.spec.js::SO-014 scenario 48"
    ],
    "visible_dom_assertions_required": true,
    "manual_prompt_regression": [],
    "tracker": "docs/qa/STATEFUL_ORACLE_TESTING_TRACK.md#phase-12-executable-enforcement-closure"
  }
}
