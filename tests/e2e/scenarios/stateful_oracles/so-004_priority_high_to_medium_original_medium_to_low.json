    {
      "approval_id": "approval-so-004-2",
      "action": "bulk_update_job_priority",
      "row_ids": [
        "JOB-SO004-MED-01",
        "JOB-SO004-MED-02"
      ],
      "from": "medium",
      "to": "low",
      "status": "success"
    }
  ],
  "expected_timeline": [
    {
      "event": "operation_started"
    },
    {
      "event": "intent_split",
      "intent_count": 2
    },
    {
      "event": "approval_requested",
      "approval_id": "approval-so-004-1"
    },
    {
      "event": "approval_decided",
      "approval_id": "approval-so-004-1",
      "decision": "accepted"
    },
    {
      "event": "commit_completed",
      "approval_id": "approval-so-004-1"
    },
    {
      "event": "approval_requested",
      "approval_id": "approval-so-004-2"
    },
    {
      "event": "approval_decided",
      "approval_id": "approval-so-004-2",
      "decision": "accepted"
    },
    {
      "event": "commit_completed",
      "approval_id": "approval-so-004-2"
    },
    {
      "event": "final_response_created"
    },
    {
      "event": "operation_completed"
    }
  ],
  "expected_sse_or_snapshot": {
    "after_first_commit": {
      "status": "WAITING_APPROVAL",
      "pending_approval_id": "approval-so-004-2",
      "second_approval_row_ids": [
        "JOB-SO004-MED-01",
        "JOB-SO004-MED-02"
      ]
    },
    "terminal": {
      "status": "COMPLETED",
      "pending_approval_id": null,
      "timeline_contains_approval_ids": [
        "approval-so-004-1",
        "approval-so-004-2"
      ]
    }
  },
  "expected_final_response": {
    "allowed_after": "commit_completed approval-so-004-2",
    "must_include": [
      "2 high priority jobs changed to medium",
      "2 original medium priority jobs changed to low"
    ],
    "must_not_include": [
      "4 medium priority jobs changed to low",
      "newly medium jobs changed to low"
    ]
  },
  "expected_ui": {
    "approval_cards_in_order": [
      "approval-so-004-1",
      "approval-so-004-2"
    ],
    "final_state_visible_only_after": "approval-so-004-2 accepted and committed",
    "must_show": [
      "Run complete",
      "2 original medium priority jobs changed to low"
    ],
    "must_not_show": [
      "Factory Agent needs attention"
    ]
  },
  "expected_unchanged_rows": [
    {
      "id": "JOB-SO004-LOW-01",
      "priority": "low"
    }
  ],
  "invariants": [
    "approval_ids_are_distinct",
    "original_state_semantics",
    "commit_matches_approval_bundle",
    "final_summary_matches_commits",
    "timeline_contains_transition_chain"
  ],
  "required_layers": [
    "pytest_graph",
    "seeded_full_stack"
  ],
  "weakness_from_phase0": "Existing cascade coverage can prove the prompt split while missing whether the second source set used original medium rows instead of rows changed by approval 1.",
  "executable_enforcement": {
    "pytest": [
      "factory-agent/tests/test_snapshot_timeline_final_response_contract.py::test_all_stateful_oracle_files_have_executable_snapshot_final_response_contract",
      "factory-agent/tests/test_langgraph_state_machine_oracles.py::test_priority_cascade_oracles_use_original_state_for_second_write_set"
    ],
    "playwright": [
      "eMas Front/e2e/specs/full-stack-prompt-workflow-regression.spec.js::SO-004 scenario 119"
    ],
    "visible_dom_assertions_required": true,
    "manual_prompt_regression": [],
    "tracker": "docs/qa/STATEFUL_ORACLE_TESTING_TRACK.md#phase-12-executable-enforcement-closure"
  }
}
