{
  "id": "SO-004",
  "title": "High priority jobs to medium, then original medium priority jobs to low",
  "risk": "Reverse cascade ordering can treat newly changed high-priority rows as medium rows for the second approval.",
  "prompt": "Change all high priority jobs to medium, then change all original medium priority jobs to low.",
  "initial_state": {
    "jobs": [
      {
        "id": "JOB-SO004-HIGH-01",
        "priority": "high",
        "status": "open"
      },
      {
        "id": "JOB-SO004-HIGH-02",
        "priority": "high",
        "status": "open"
      },
      {
        "id": "JOB-SO004-MED-01",
        "priority": "medium",
        "status": "open"
      },
      {
        "id": "JOB-SO004-MED-02",
        "priority": "medium",
        "status": "open"
      },
      {
        "id": "JOB-SO004-LOW-01",
        "priority": "low",
        "status": "open"
      }
    ],
    "approvals": [],
    "audit_rows": [],
    "source_set_semantics": "original_state_for_each_user_clause"
  },
  "expected_intents": [
    {
      "intent_id": "SO-004-I1",
      "route": "tool.write.jobs.bulk_update_priority",
      "filter": {
        "priority": "high"
      },
      "new_values": {
        "priority": "medium"
      },
      "source_row_ids": [
        "JOB-SO004-HIGH-01",
        "JOB-SO004-HIGH-02"
      ]
    },
    {
      "intent_id": "SO-004-I2",
      "route": "tool.write.jobs.bulk_update_priority",
      "filter": {
        "priority": "medium",
        "state_basis": "original"
      },
      "new_values": {
        "priority": "low"
      },
      "source_row_ids": [
        "JOB-SO004-MED-01",
        "JOB-SO004-MED-02"
      ]
    }
  ],
  "expected_approvals": [
    {
      "approval_id": "approval-so-004-1",
      "intent_id": "SO-004-I1",
      "decision": "accepted",
      "previous_priority": "high",
      "new_priority": "medium",
      "row_ids": [
        "JOB-SO004-HIGH-01",
        "JOB-SO004-HIGH-02"
      ],
      "row_count": 2
    },
    {
      "approval_id": "approval-so-004-2",
      "intent_id": "SO-004-I2",
      "decision": "accepted",
      "previous_priority": "medium",
      "new_priority": "low",
      "row_ids": [
        "JOB-SO004-MED-01",
        "JOB-SO004-MED-02"
      ],
      "row_count": 2
    }
  ],
  "expected_intermediate_states": [
    {
      "after": "approval-so-004-1 commit",
      "session_phase": "WAITING_APPROVAL",
      "pending_approval_id": "approval-so-004-2",
      "jobs": [
        {
          "id": "JOB-SO004-HIGH-01",
          "priority": "medium"
        },
        {
          "id": "JOB-SO004-HIGH-02",
          "priority": "medium"
        },
        {
          "id": "JOB-SO004-MED-01",
          "priority": "medium"
        },
        {
          "id": "JOB-SO004-MED-02",
          "priority": "medium"
        },
        {
          "id": "JOB-SO004-LOW-01",
          "priority": "low"
        }
      ],
      "forbidden_second_approval_rows": [
        "JOB-SO004-HIGH-01",
        "JOB-SO004-HIGH-02"
      ]
    }
  ],
  "expected_final_state": {
    "session_phase": "COMPLETED",
    "jobs": [
      {
        "id": "JOB-SO004-HIGH-01",
        "priority": "medium"
      },
      {
        "id": "JOB-SO004-HIGH-02",
        "priority": "medium"
      },
      {
        "id": "JOB-SO004-MED-01",
        "priority": "low"
      },
      {
        "id": "JOB-SO004-MED-02",
        "priority": "low"
      },
      {
        "id": "JOB-SO004-LOW-01",
        "priority": "low"
      }
    ],
    "pending_approval_id": null
  },
  "expected_audit_rows": [
    {
      "approval_id": "approval-so-004-1",
      "action": "bulk_update_job_priority",
      "row_ids": [
        "JOB-SO004-HIGH-01",
        "JOB-SO004-HIGH-02"
