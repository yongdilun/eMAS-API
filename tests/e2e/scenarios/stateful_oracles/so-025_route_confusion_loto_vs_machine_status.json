{
  "id": "SO-025",
  "title": "Route confusion: LOTO vs machine status",
  "risk": "A safety-procedure prompt can be routed to a machine status tool, producing a plausible but wrong answer without LOTO source evidence.",
  "prompt": "For M-CNC-01, tell me the lockout tagout steps, not the current machine status.",
  "initial_state": {
    "machines": [
      {
        "id": "M-CNC-01",
        "status": "running",
        "cell": "CNC"
      }
    ],
    "rag_sources": [
      {
        "source_id": "SRC-LOTO-CNC-01",
        "machine_id": "M-CNC-01",
        "title": "LOTO Procedure for CNC Cell"
      }
    ],
    "approvals": [],
    "audit_rows": []
  },
  "expected_route": {
    "route": "rag.loto_procedure",
    "machine_id": "M-CNC-01",
