  ],
  "expected_final_state": {
    "session_phase": "COMPLETED",
    "machines": [
      {
        "id": "M-CNC-01",
        "status": "running",
        "cell": "CNC"
      }
    ],
    "pending_approval_id": null
  },
  "expected_audit_rows": [],
  "expected_timeline": [
    {
      "event": "operation_started"
    },
    {
      "event": "intent_split",
      "intent_count": 1
    },
    {
