{
  "id": "SO-027",
  "title": "User sends revision while waiting approval",
  "risk": "A superseding user revision can leave the old pending approval active, allowing an outdated mutation after the operator changes intent.",
  "prompt": "Change all high priority jobs to medium. Before approval, revise to cancel that and change all low priority jobs to medium.",
  "initial_state": {
    "jobs": [
      {
        "id": "JOB-SO027-HIGH-01",
        "priority": "high",
        "status": "open"
      },
      {
        "id": "JOB-SO027-LOW-01",
        "priority": "low",
        "status": "open"
      },
      {
        "id": "JOB-SO027-MED-01",
        "priority": "medium",
        "status": "open"
      }
    ],
    "approvals": [],
    "audit_rows": [],
    "revision_policy": "invalidate_pending_approval_on_new_write_intent"
  },
  "expected_intents": [
    {
      "intent_id": "SO-027-I1",
      "route": "tool.write.jobs.bulk_update_priority",
      "filter": {
        "priority": "high"
      },
      "new_values": {
        "priority": "medium"
      },
      "source_row_ids": [
        "JOB-SO027-HIGH-01"
      ],
      "expected_status_after_revision": "superseded"
    },
    {
      "intent_id": "SO-027-I2",
      "route": "tool.write.jobs.bulk_update_priority",
      "filter": {
        "priority": "low"
      },
      "new_values": {
        "priority": "medium"
      },
      "source_row_ids": [
        "JOB-SO027-LOW-01"
      ]
    }
  ],
  "expected_approvals": [
    {
      "approval_id": "approval-so-027-old",
      "intent_id": "SO-027-I1",
      "decision": "superseded",
      "row_ids": [
        "JOB-SO027-HIGH-01"
      ],
      "row_count": 1,
      "late_approve_attempt": "rejected_409_stale_approval"
    },
    {
      "approval_id": "approval-so-027-new",
      "intent_id": "SO-027-I2",
      "decision": "accepted",
      "row_ids": [
        "JOB-SO027-LOW-01"
      ],
      "row_count": 1
    }
  ],
  "expected_intermediate_states": [
    {
      "after": "old approval requested",
      "session_phase": "WAITING_APPROVAL",
      "pending_approval_id": "approval-so-027-old"
    },
    {
      "after": "revision received",
      "session_phase": "WAITING_APPROVAL",
      "pending_approval_id": "approval-so-027-new",
      "invalidated_approval_ids": [
        "approval-so-027-old"
      ],
      "forbidden": [
        "commit_completed approval-so-027-old"
      ]
    }
  ],
  "expected_final_state": {
    "session_phase": "COMPLETED",
    "jobs": [
      {
        "id": "JOB-SO027-HIGH-01",
        "priority": "high"
      },
      {
        "id": "JOB-SO027-LOW-01",
        "priority": "medium"
      },
      {
        "id": "JOB-SO027-MED-01",
        "priority": "medium"
      }
    ],
    "pending_approval_id": null
  },
  "expected_audit_rows": [
    {
      "approval_id": "approval-so-027-new",
      "action": "bulk_update_job_priority",
      "row_ids": [
        "JOB-SO027-LOW-01"
      ],
      "from": "low",
      "to": "medium",
      "status": "success"
    }
  ],
  "expected_timeline": [
    {
      "event": "operation_started"
    },
    {
      "event": "approval_requested",
      "approval_id": "approval-so-027-old"
    },
    {
      "event": "user_revision_received"
    },
    {
      "event": "approval_invalidated",
      "approval_id": "approval-so-027-old"
    },
    {
      "event": "approval_requested",
      "approval_id": "approval-so-027-new"
    },
    {
      "event": "approval_decided",
      "approval_id": "approval-so-027-new",
      "decision": "accepted"
    },
    {
      "event": "commit_completed",
      "approval_id": "approval-so-027-new"
    },
    {
      "event": "final_response_created"
    },
    {
      "event": "operation_completed"
    }
  ],
  "expected_sse_or_snapshot": {
    "after_revision": {
      "status": "WAITING_APPROVAL",
      "pending_approval_id": "approval-so-027-new",
      "must_not_show_pending_approval_ids": [
        "approval-so-027-old"
      ]
    },
    "terminal": {
      "status": "COMPLETED",
      "pending_approval_id": null
    }
  },
  "expected_final_response": {
    "allowed_after": "commit_completed approval-so-027-new",
    "must_include": [
      "1 low priority job changed to medium"
    ],
    "must_not_include": [
      "1 high priority job changed to medium",
      "old approval was applied"
    ]
  },
  "expected_ui": {
    "approval_cards_in_order": [
      "approval-so-027-old",
      "approval-so-027-new"
    ],
    "must_show": [
      "Superseded",
      "1 low priority job changed to medium"
    ],
    "must_not_show": [
      "1 high priority job changed to medium",
      "Factory Agent needs attention"
    ]
  },
  "expected_unchanged_rows": [
    {
      "id": "JOB-SO027-HIGH-01",
      "priority": "high"
    },
    {
      "id": "JOB-SO027-MED-01",
      "priority": "medium"
    }
  ],
  "invariants": [
    "user_revision_invalidates_pending_approval",
    "stale_approval_cannot_commit",
    "pending_approval_matches_snapshot",
    "commit_matches_current_approval_bundle",
    "final_summary_matches_commits"
  ],
  "required_layers": [
    "pytest_api",
    "browser"
  ],
  "weakness_from_phase0": "Phase 0 called out revision while approval is pending as a separate risk from ordinary stale replay; this oracle proves the superseding turn owns the only commit.",
  "executable_enforcement": {
    "pytest": [
      "factory-agent/tests/test_snapshot_timeline_final_response_contract.py::test_all_stateful_oracle_files_have_executable_snapshot_final_response_contract"
    ],
    "playwright": [
      "eMas Front/e2e/specs/full-stack-data-integrity.spec.js::SO-006/SO-008/SO-027 scenario 89"
    ],
    "visible_dom_assertions_required": true,
    "manual_prompt_regression": [],
    "tracker": "docs/qa/STATEFUL_ORACLE_TESTING_TRACK.md#phase-12-executable-enforcement-closure"
  }
}
