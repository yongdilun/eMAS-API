{
  "id": "SO-013",
  "title": "SSE sends completion before snapshot terminal",
  "risk": "The browser can render a final answer from an SSE completion event before the authoritative snapshot has reached a terminal state.",
  "prompt": "Change all high priority jobs to medium.",
  "initial_state": {
    "jobs": [
      {
        "id": "JOB-SO013-HIGH-01",
        "priority": "high",
        "status": "open"
      },
      {
        "id": "JOB-SO013-HIGH-02",
        "priority": "high",
        "status": "open"
      },
      {
        "id": "JOB-SO013-LOW-01",
        "priority": "low",
        "status": "open"
      }
    ],
    "approvals": [],
    "audit_rows": [],
    "stream_mode": "eventsource_with_snapshot_confirmation"
  },
  "expected_intents": [
    {
      "intent_id": "SO-013-I1",
      "route": "tool.write.jobs.bulk_update_priority",
      "filter": {
        "priority": "high"
      },
      "new_values": {
        "priority": "medium"
      },
      "source_row_ids": [
        "JOB-SO013-HIGH-01",
        "JOB-SO013-HIGH-02"
      ]
    }
  ],
  "expected_approvals": [
    {
      "approval_id": "approval-so-013-1",
      "intent_id": "SO-013-I1",
      "decision": "accepted",
      "previous_priority": "high",
      "new_priority": "medium",
      "row_ids": [
        "JOB-SO013-HIGH-01",
        "JOB-SO013-HIGH-02"
      ],
      "row_count": 2
    }
  ],
  "expected_intermediate_states": [
    {
      "after": "approval accepted before commit completes",
      "session_phase": "EXECUTING",
      "pending_approval_id": null,
      "snapshot_status": "EXECUTING",
      "forbidden": [
        "sse operation_completed",
        "terminal_assistant_message",
        "Run complete"
      ]
    },
    {
      "after": "commit completed before terminal snapshot persisted",
      "session_phase": "EXECUTING",
      "snapshot_status": "EXECUTING",
      "timeline_must_include": [
        "commit_completed approval-so-013-1"
      ],
      "forbidden": [
        "sse final_response_created",
        "sse operation_completed",
        "browser_final_response"
      ]
    }
  ],
  "expected_final_state": {
    "session_phase": "COMPLETED",
    "jobs": [
      {
        "id": "JOB-SO013-HIGH-01",
        "priority": "medium"
      },
      {
        "id": "JOB-SO013-HIGH-02",
        "priority": "medium"
      },
      {
        "id": "JOB-SO013-LOW-01",
        "priority": "low"
      }
    ],
    "pending_approval_id": null,
    "snapshot_status": "COMPLETED"
  },
  "expected_audit_rows": [
    {
      "approval_id": "approval-so-013-1",
      "action": "bulk_update_job_priority",
      "row_ids": [
        "JOB-SO013-HIGH-01",
        "JOB-SO013-HIGH-02"
      ],
      "from": "high",
      "to": "medium",
      "status": "success"
    }
  ],
  "expected_timeline": [
    {
      "event": "operation_started"
    },
    {
      "event": "approval_requested",
      "approval_id": "approval-so-013-1"
    },
    {
      "event": "approval_decided",
      "approval_id": "approval-so-013-1",
      "decision": "accepted"
    },
    {
      "event": "commit_started",
      "approval_id": "approval-so-013-1"
    },
    {
      "event": "commit_completed",
      "approval_id": "approval-so-013-1"
    },
    {
      "event": "snapshot_terminal_persisted",
      "status": "COMPLETED"
    },
    {
      "event": "final_response_created"
    },
    {
      "event": "operation_completed"
    },
    {
      "event": "sse_completion_emitted",
      "allowed_after": "snapshot_terminal_persisted"
    }
  ],
  "expected_sse_or_snapshot": {
    "ordering_contract": {
      "sse_completion_allowed_after_snapshot_status": "COMPLETED",
      "sse_completion_must_not_precede": [
        "snapshot_terminal_persisted",
        "final_response_created"
      ],
      "browser_final_allowed_after": "snapshot_status COMPLETED"
    },
    "before_terminal_snapshot": {
      "snapshot_status": "EXECUTING",
      "must_ignore_sse_events": [
        "operation_completed",
        "final_response_created"
      ]
    },
    "terminal": {
      "status": "COMPLETED",
      "pending_approval_id": null,
      "timeline_contains_approval_ids": [
        "approval-so-013-1"
      ]
    }
  },
  "expected_final_response": {
    "allowed_after": "snapshot_status COMPLETED",
    "must_include": [
      "2 high priority jobs changed to medium"
    ],
    "must_not_include": [
      "completed while still executing",
      "shown before snapshot terminal"
    ]
  },
  "expected_ui": {
    "approval_cards_in_order": [
      "approval-so-013-1"
    ],
    "before_terminal_snapshot_must_not_show": [
      "Run complete",
      "2 high priority jobs changed to medium"
    ],
    "must_show_after_terminal": [
      "Run complete",
      "2 high priority jobs changed to medium"
    ],
    "must_not_show": [
      "Factory Agent needs attention"
    ]
  },
  "expected_unchanged_rows": [
    {
      "id": "JOB-SO013-LOW-01",
      "priority": "low"
    }
  ],
  "invariants": [
    "sse_completion_after_terminal_snapshot",
    "sse_matches_snapshot",
    "no_final_before_terminal",
    "commit_matches_approval_bundle",
    "timeline_contains_transition_chain",
    "final_summary_matches_commits"
  ],
  "required_layers": [
    "sse_pytest",
    "playwright"
  ],
  "weakness_from_phase0": "Phase 0 found SSE tests that prove activity occurred but not that SSE, snapshot, timeline, and final UI agree; this oracle requires completion events to be gated by terminal snapshot evidence.",
  "executable_enforcement": {
    "pytest": [
      "factory-agent/tests/test_snapshot_timeline_final_response_contract.py::test_all_stateful_oracle_files_have_executable_snapshot_final_response_contract",
      "factory-agent/tests/test_phase7_api_ui_alignment.py::test_so013_activity_suppresses_completion_until_terminal_snapshot"
    ],
    "playwright": [
      "eMas Front/e2e/specs/chat-stream-errors.spec.js::non-terminal active session stays busy"
    ],
    "visible_dom_assertions_required": true,
    "manual_prompt_regression": [],
    "tracker": "docs/qa/STATEFUL_ORACLE_TESTING_TRACK.md#phase-12-executable-enforcement-closure"
  }
}
