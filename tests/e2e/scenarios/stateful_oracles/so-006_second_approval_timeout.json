{
  "id": "SO-006",
  "title": "Approval 1 accepted, approval 2 timeout",
  "risk": "A session can complete or continue after the second approval expires, leaving operators with a false success state or allowing a stale approval to mutate data later.",
  "prompt": "Change all medium priority jobs to high, then change all original high priority jobs to medium. Approve the first request and let the second approval time out.",
  "initial_state": {
    "jobs": [
      {
        "id": "JOB-SO006-HIGH-01",
        "priority": "high",
        "status": "open"
      },
      {
        "id": "JOB-SO006-HIGH-02",
        "priority": "high",
        "status": "open"
      },
      {
        "id": "JOB-SO006-MED-01",
        "priority": "medium",
        "status": "open"
      },
      {
        "id": "JOB-SO006-LOW-01",
        "priority": "low",
        "status": "open"
      }
    ],
    "approvals": [],
    "audit_rows": [],
    "approval_timeout_seconds": 900
  },
  "expected_intents": [
    {
      "intent_id": "SO-006-I1",
      "route": "tool.write.jobs.bulk_update_priority",
      "filter": {
        "priority": "medium"
      },
      "new_values": {
        "priority": "high"
      },
      "source_row_ids": [
        "JOB-SO006-MED-01"
      ]
    },
    {
      "intent_id": "SO-006-I2",
      "route": "tool.write.jobs.bulk_update_priority",
      "filter": {
        "priority": "high",
        "state_basis": "original"
      },
      "new_values": {
        "priority": "medium"
      },
      "source_row_ids": [
        "JOB-SO006-HIGH-01",
        "JOB-SO006-HIGH-02"
      ]
    }
  ],
  "expected_approvals": [
    {
      "approval_id": "approval-so-006-1",
      "intent_id": "SO-006-I1",
      "decision": "accepted",
      "row_ids": [
        "JOB-SO006-MED-01"
      ],
      "row_count": 1
    },
    {
      "approval_id": "approval-so-006-2",
      "intent_id": "SO-006-I2",
      "decision": "expired",
      "row_ids": [
        "JOB-SO006-HIGH-01",
        "JOB-SO006-HIGH-02"
      ],
      "row_count": 2,
      "late_approve_attempt": "rejected_409_expired_approval"
    }
  ],
  "expected_intermediate_states": [
    {
      "after": "approval-so-006-1 commit",
      "session_phase": "WAITING_APPROVAL",
      "pending_approval_id": "approval-so-006-2",
      "jobs": [
        {
          "id": "JOB-SO006-HIGH-01",
          "priority": "high"
        },
        {
          "id": "JOB-SO006-HIGH-02",
          "priority": "high"
        },
        {
          "id": "JOB-SO006-MED-01",
          "priority": "high"
        },
        {
          "id": "JOB-SO006-LOW-01",
          "priority": "low"
        }
      ]
    },
    {
      "after": "approval-so-006-2 expired",
      "session_phase": "EXPIRED",
      "pending_approval_id": null,
      "forbidden": [
        "commit_started approval-so-006-2",
        "operation_completed",
        "final_success_response"
      ]
    }
  ],
  "expected_final_state": {
    "session_phase": "EXPIRED",
    "jobs": [
      {
        "id": "JOB-SO006-HIGH-01",
        "priority": "high"
      },
      {
        "id": "JOB-SO006-HIGH-02",
        "priority": "high"
      },
      {
        "id": "JOB-SO006-MED-01",
        "priority": "high"
      },
      {
        "id": "JOB-SO006-LOW-01",
        "priority": "low"
      }
    ],
    "pending_approval_id": null
  },
  "expected_audit_rows": [
    {
      "approval_id": "approval-so-006-1",
      "action": "bulk_update_job_priority",
      "row_ids": [
        "JOB-SO006-MED-01"
      ],
      "from": "medium",
      "to": "high",
      "status": "success"
    }
  ],
  "expected_timeline": [
    {
      "event": "operation_started"
    },
    {
      "event": "intent_split",
      "intent_count": 2
    },
    {
      "event": "approval_requested",
      "approval_id": "approval-so-006-1"
    },
    {
      "event": "approval_decided",
      "approval_id": "approval-so-006-1",
      "decision": "accepted"
    },
    {
      "event": "commit_completed",
      "approval_id": "approval-so-006-1"
    },
    {
      "event": "approval_requested",
      "approval_id": "approval-so-006-2"
    },
    {
      "event": "approval_expired",
      "approval_id": "approval-so-006-2"
    },
    {
      "event": "operation_expired",
      "reason": "approval_timeout"
    }
  ],
  "expected_sse_or_snapshot": {
    "after_timeout": {
      "status": "EXPIRED",
      "pending_approval_id": null,
      "must_not_include_events": [
        "commit_completed approval-so-006-2",
        "operation_completed"
      ]
    }
  },
  "expected_final_response": {
    "allowed_after": "approval_expired approval-so-006-2",
    "must_include": [
      "First change was committed",
      "second approval expired"
    ],
    "must_not_include": [
      "all requested changes completed",
      "2 original high priority jobs changed to medium"
    ]
  },
  "expected_ui": {
    "approval_cards_in_order": [
      "approval-so-006-1",
      "approval-so-006-2"
    ],
    "must_show": [
      "Expired",
      "First change was committed"
    ],
    "must_not_show": [
      "Run complete",
      "2 original high priority jobs changed to medium"
    ]
  },
  "expected_unchanged_rows": [
    {
      "id": "JOB-SO006-HIGH-01",
      "priority": "high"
    },
    {
      "id": "JOB-SO006-HIGH-02",
      "priority": "high"
    },
    {
      "id": "JOB-SO006-LOW-01",
      "priority": "low"
    }
  ],
  "invariants": [
    "approval_ids_are_distinct",
    "expired_approval_cannot_commit",
    "no_commit_after_expired_approval",
    "pending_approval_matches_snapshot",
    "timeline_contains_transition_chain",
    "final_summary_matches_commits"
  ],
  "required_layers": [
    "pytest_graph",
    "seeded_full_stack"
  ],
  "weakness_from_phase0": "Timeout tests previously proved a pending state but not that late approval cannot commit or that final success is suppressed after expiry.",
  "executable_enforcement": {
    "pytest": [
      "factory-agent/tests/test_snapshot_timeline_final_response_contract.py::test_all_stateful_oracle_files_have_executable_snapshot_final_response_contract"
    ],
    "playwright": [
      "eMas Front/e2e/specs/full-stack-data-integrity.spec.js::SO-006/SO-008/SO-027 scenario 89"
    ],
    "visible_dom_assertions_required": true,
    "manual_prompt_regression": [],
    "tracker": "docs/qa/STATEFUL_ORACLE_TESTING_TRACK.md#phase-12-executable-enforcement-closure"
  }
}
