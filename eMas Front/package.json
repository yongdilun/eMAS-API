{
  "name": "emas",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "node --test --test-concurrency=1 \"src/components/features/chat/factory-agent/activityTimeline.test.mjs\" \"src/components/features/chat/factory-agent/approvalInterruptDisplay.test.mjs\" \"src/components/features/chat/factory-agent/approvalFieldUtils.test.mjs\" \"src/components/features/chat/factory-agent/responseDocumentReducer.test.mjs\" \"src/components/features/chat/turns/turnAssembler.test.mjs\" \"src/components/features/chat/factory-agent/ApprovalCard.component.test.mjs\" \"src/components/features/chat/factory-agent/ActivityTimeline.component.test.mjs\" \"src/components/features/chat/factory-agent/FactoryAgentChatPanel.component.test.mjs\" \"src/context/ToastContext.component.test.mjs\" \"src/components/features/reports/noFakeData.component.test.mjs\" \"e2e/support/factoryAgentTransitionOracle.test.mjs\" \"e2e/support/responseDocumentProbe.test.mjs\"",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "verify-overlaps": "node scripts/verify-overlaps.js",
    "factory-agent-smoke": "node scripts/factory-agent-smoke.js",
    "test:backend-oracles": "cd ../factory-agent && python -m pytest tests/test_stateful_oracle_schema.py tests/test_phase18_manual_prompt_bank.py tests/test_stateful_oracle_harness.py tests/test_langgraph_state_machine_oracles.py tests/test_snapshot_timeline_final_response_contract.py tests/test_phase7_api_ui_alignment.py tests/test_phase19_prompt_workflow_regression.py tests/test_summary_bundle.py tests/test_event_stream_runtime.py tests/test_hardcode_guardrails.py -q",
    "test:e2e": "playwright test",
    "test:e2e:mocked": "playwright test --project=chromium",
    "test:e2e:response-document": "playwright test --project=chromium --grep \"response_document|final response|approval|event storm\"",
    "test:e2e:seeded-oracles": "playwright test --project=chromium-seeded --grep \"@data-integrity|@prompt-regression|@sse\"",
    "test:e2e:real-langgraph": "playwright test --project=chromium-real-langgraph --grep @critical",
    "test:e2e:release": "playwright test --project=chromium-release",
    "test:e2e:synthetic": "playwright test --project=chromium-synthetic",
    "test:e2e:reliability": "playwright test --project=chromium --grep @reliability",
    "test:e2e:reliability:seeded": "playwright test --project=chromium-seeded --grep @reliability",
    "test:e2e:operational": "playwright test --project=chromium --grep @operational",
    "operational:gate": "node e2e/support/operationalGate.js",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "pdfjs-dist": "^5.7.284",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.8"
  }
}
